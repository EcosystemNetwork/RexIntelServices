# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gitnexus

# investigations — raw forensic output (voter dumps, etc.). Don't commit
# the data itself; the script is committed so we can re-run on demand.
scripts/.casper-forensics-output/

# Secret-bearing recovery / plaintext files. These should never live on
# the tracked tree. Caught Circle's entity-secret-recovery.dat once —
# don't catch the next one.
*-secret-recovery.dat
*.secret.plaintext.txt
*-entity-secret-*.dat
