# ─── Database (Neon) ─────────────────────────────────
# Use the POOLED endpoint (host contains "-pooler"). The serverless driver
# expects sslmode=require. Find this string in the Neon dashboard under
# "Connection Details" → "Pooled connection".
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ─── Resend (email sending) ──────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ─── Application ─────────────────────────────────────
# Server-side base URL. Used by absoluteUrl() for outbound links in emails,
# cron handlers, and OTP confirmation redirects. Set to your prod origin
# on Vercel; localhost is fine for dev.
APP_URL=http://localhost:3000

# Client-exposed base URL. Used by browser code that needs to build
# canonical URLs (OG fallbacks, share intents). MUST match APP_URL in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
SESSION_PASSWORD=your-32-char-minimum-session-secret-here

# ─── Operator (admin) allowlist ──────────────────────
# Comma-separated list of emails permitted to sign into the admin portal
# via Magic Link. REQUIRED — if unset, no one can log in to /dashboard.
# Case-insensitive; whitespace trimmed.
OPERATOR_EMAILS=rexintelservices@proton.me

# ─── Vercel Cron ─────────────────────────────────────
# Generate with: openssl rand -hex 32
# Vercel Cron sends this as `Authorization: Bearer <value>` to /api/cron/*.
# Must match between the running app and the Vercel project env vars.
CRON_SECRET=your-cron-bearer-token-here

# ─── Weekly Digest ───────────────────────────────────
# /api/cron/draft-digest creates a draft campaign every Sunday 22:00 UTC.
# Must be a domain verified in Resend.
DIGEST_FROM_EMAIL=briefing@yourdomain.com
DIGEST_FROM_NAME=Rex Intel Services
# Set to "true" to bypass the editorial-bar guard (no original/incident intel
# required). Default is false — cron skips draft creation if the week has no
# original or incident-class intel.
# DIGEST_BYPASS_EDITORIAL_BAR=false

# ─── Upstash Redis (rate-limit + cache) ──────────────
# Either pair works; the Vercel KV integration auto-provisions KV_REST_API_*,
# while a standalone Upstash project uses UPSTASH_REDIS_REST_*. The code
# reads either set. Required for vote rate-limiting and Turnstile token
# replay protection.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ─── Cloudflare Turnstile (anti-bot) ─────────────────
# Gates public mutations: /submit, /subscribe, /trace, vote/start. Site key
# is exposed to the browser; secret stays server-side. If unset, gates fall
# open in dev — set TURNSTILE_FAIL_OPEN=false to harden in staging.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxx
# TURNSTILE_FAIL_OPEN=true

# ─── Vote-cookie HMAC (30-day fast path) ─────────────
# Signs the long-lived browser cookie that bypasses re-confirmation for the
# 30-day window. Generate with: openssl rand -base64 32.
VOTER_COOKIE_SECRET=your-32-char-minimum-cookie-secret

# ─── Victim trace (Etherscan v1) ─────────────────────
# Powers /trace — outbound BFS over ETH + internal + ERC-20 transfers.
# Register a free key at https://etherscan.io/myapikey (5 req/sec,
# 100k req/day). Optional ETHERSCAN_RPS override (default 4).
ETHERSCAN_API_KEY=your-etherscan-api-key
# ETHERSCAN_RPS=4

# ─── Address-attribution harvesters ──────────────────
# All have sane defaults baked in; override only when the upstream URL
# moves or you want to point at a mirror.
# OFAC_SDN_URL=https://www.treasury.gov/ofac/downloads/sdn.xml
# OPENSANCTIONS_BASE=https://data.opensanctions.org
# L2BEAT_API_URL=https://l2beat.com/api/tvl/scaling/breakdown.json

# ─── Gemini editor cron ──────────────────────────────
# Daily 16:00 UTC. Drafts ≥$1M DefiLlama hacks as pending intel using
# Gemini Pro. Without this key, the cron logs and no-ops.
GEMINI_API_KEY=your-gemini-api-key

# ─── Magic Link (user sign-in) ───────────────────────
# Used by /api/auth/magic/* for email-onboarded contributor wallets that
# gate claim submission, sealed-payload intel, prize-pool claims, etc.
#
# `pk_live_...` / `sk_live_...` are mainnet; `pk_test_...` / `sk_test_...`
# are sandbox. The publishable key is exposed to the browser; keep the
# secret strictly server-side. Key/chain MUST match: pk_live_ + chainId
# 8453, or pk_test_ + chainId 84532 — mismatch surfaces as a generic
# 401 from Magic that is invisible without console-diving.
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx
MAGIC_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_MAGIC_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_MAGIC_CHAIN_ID=8453
# Server-side chain ID variant used by the admin SDK. MUST match the
# NEXT_PUBLIC_ variant. If unset, defaults to the public value.
# MAGIC_CHAIN_ID=8453

# ─── Ops alerting ────────────────────────────────────
# Recipient for sendOpsAlert() — wired into settle-monthly-prizes
# distribute() failures, awardPrizeWin failures, request-otp send failures,
# harvester crons, and index-bounty-escrow RPC errors. Without this set,
# every alert path silently no-ops. Solo operator → no on-call → this MUST
# be set in prod.
ADMIN_ALERT_EMAIL=rexintelservices@proton.me

# ─── Bounty escrow rail ──────────────────────────────
# Recovery + info bounties are gated behind this flag while the on-chain
# custody rail is finalized. Flip to "true" once BountyEscrow is deployed
# and BOUNTY_ESCROW_ADDRESS below is set.
BOUNTY_CUSTODY_RAIL_ENABLED=false

# Refundable claim-submit bond in USDC. DEFAULTS TO 0. Do not set non-zero
# until the on-chain bond collection rail is wired up — charging a bond
# without collecting it drains the bounty escrow on refund/slash.
# BOUNTY_CLAIM_BOND_USDC=0

# On-chain BountyEscrow indexer config (used by /api/cron/index-bounty-escrow
# every 10 min). All four required when BOUNTY_CUSTODY_RAIL_ENABLED=true.
# IMPORTANT: do NOT use the public mainnet.base.org RPC for the indexer —
# its rate limits will brick the */10 cron at scale. Provision a dedicated
# Alchemy / QuickNode / Ankr endpoint.
# BOUNTY_ESCROW_ADDRESS=0x...
# BOUNTY_ESCROW_CHAIN=base                 # base | base-sepolia
# BOUNTY_ESCROW_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<key>
# BOUNTY_ESCROW_TOKEN_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# ─── Community prize pool (IntelPrizePool on Base mainnet) ─────
# REQUIRED FOR MAINNET — none of these may be left at the placeholder.
# Once PRIZE_POOL_ADDRESS is set, /api/cron/settle-monthly-prizes will
# call distribute() on the 1st of every month from SETTLER_PRIVATE_KEY.
# Verify the full surface via /api/admin/onchain/preflight before the
# 1st-of-month cron fires.
#
# A malformed PRIZE_POOL_ADDRESS throws at config-parse time (was silently
# null-skipped before). Either leave it unset entirely or set it to a real
# 0x-prefixed 40-hex address.
# Same RPC warning as BOUNTY_ESCROW_RPC_URL — use a dedicated endpoint.
# PRIZE_POOL_ADDRESS=0x...                # deployed IntelPrizePool address
# PRIZE_POOL_CHAIN=base                   # base | base-sepolia
# PRIZE_POOL_ASSET=USDC
# PRIZE_POOL_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<key>
# PRIZE_POOL_TOKEN_CONTRACT defaults to bridged USDC on Base
# (0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913) — only set when overriding.
# PRIZE_POOL_TOKEN_CONTRACT=

# Server-only — the EOA the IntelPrizePool contract authorized as settler.
# Used by /api/cron/settle-monthly-prizes to sign distribute() each month.
# A leaked key lets an attacker call distribute() and rescue() of non-USDC
# tokens, but cannot drain the USDC pool itself (no settler-side withdraw).
# Rotate via proposeSettler()+acceptSettler() if compromised — see
# contracts/RECOVERY.md.
#
# Format: 0x-prefixed 32-byte hex (64 hex chars after the 0x). Generate
# offline with `cast wallet new`; store the raw key only in 1Password +
# Vercel env. Fund the derived EOA with ≥ 0.05 ETH on Base mainnet before
# the first distribute() call.
# SETTLER_PRIVATE_KEY=0x...

# Settler EOA low-gas-balance alert threshold (wei). Below this, the
# submitDistribute helper logs a warning. Defaults to 0.005 ETH
# (5_000_000_000_000_000) — roughly 25 distribute() calls of headroom on
# Base mainnet. Set higher if you want earlier paging.
# SETTLER_LOW_GAS_WEI=5000000000000000

# Optional staging override: when set, the leaderboard renders this value
# verbatim instead of reading the contract balance. IGNORED in production
# (NODE_ENV=production) so a stale staging env can't fake the pool size.
# PRIZE_POOL_MOCK_BALANCE=
