# ─── Database (Neon) ─────────────────────────────────
# Use the POOLED endpoint (host contains "-pooler"). The serverless driver
# expects sslmode=require. Find this string in the Neon dashboard under
# "Connection Details" → "Pooled connection".
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ─── Resend (email sending) ──────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# ─── Application ─────────────────────────────────────
APP_URL=http://localhost:3000

# Generate with: openssl rand -base64 32
SESSION_PASSWORD=your-32-char-minimum-session-secret-here

# ─── Vercel Cron ─────────────────────────────────────
# Generate with: openssl rand -hex 32
# Vercel Cron sends this as `Authorization: Bearer <value>` to /api/cron/*.
# Must match between the running app and the Vercel project env vars.
CRON_SECRET=your-cron-bearer-token-here

# ─── Weekly Digest ───────────────────────────────────
# /api/cron/draft-digest creates a draft campaign every Sunday 22:00 UTC.
# Must be a domain verified in Resend.
DIGEST_FROM_EMAIL=briefing@yourdomain.com
DIGEST_FROM_NAME=Rex Intel Services

# ─── Victim trace (Etherscan v1) ─────────────────────
# Powers /trace — outbound BFS over ETH + internal + ERC-20 transfers.
# Register a free key at https://etherscan.io/myapikey (5 req/sec,
# 100k req/day). Optional ETHERSCAN_RPS override (default 4).
ETHERSCAN_API_KEY=your-etherscan-api-key
# ETHERSCAN_RPS=4

# ─── Circle programmable wallets (user sign-in) ──────
# Used by /api/auth/circle/* for the email-onboarded user wallets that gate
# claim submission etc. Different surface from the bounty escrow rail below.
CIRCLE_API_KEY=TEST_API_KEY:...           # LIVE_API_KEY:... for mainnet
CIRCLE_APP_ID=your-circle-app-id          # Console → App → App ID
NEXT_PUBLIC_CIRCLE_APP_ID=your-circle-app-id
CIRCLE_BLOCKCHAIN=BASE                    # BASE-SEPOLIA in sandbox
# CIRCLE_BASE_URL=https://api.circle.com  # rarely overridden

# ─── Bounty escrow rail (Circle Developer-Controlled Wallets) ────────
# Run `npx tsx scripts/provision-bounty-escrow.ts` once per environment to
# generate the entity secret + wallet set. The script prints the values to
# paste here (or into Vercel).
CIRCLE_ENTITY_SECRET=                     # 64-char hex (32 bytes), single-use ciphertext per request
CIRCLE_BOUNTY_WALLET_SET_ID=              # parent wallet set; runtime makes one wallet per bounty inside it
CIRCLE_BOUNTY_BLOCKCHAIN=BASE             # BASE-SEPOLIA in sandbox
CIRCLE_BOUNTY_USDC_TOKEN_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# Sandbox USDC on Base-Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e

# RSA-SHA256 PEM from Circle Console → Webhooks → (your subscription) → Public Key.
# Webhook handler 401s every delivery without it, so inbound deposits never
# apply and bounties stay stuck in draft. Multi-line value — paste the PEM
# literally including BEGIN/END lines.
CIRCLE_WEBHOOK_PUBLIC_KEY=

# Refundable claim-submit bond in USDC. DEFAULTS TO 0. Do not set non-zero
# until the on-chain bond collection rail is wired up — charging a bond
# without collecting it drains the bounty escrow on refund/slash.
# BOUNTY_CLAIM_BOND_USDC=0

# ─── Community prize pool (testnet display only) ─────
# Visible balance on the leaderboard. v0 ships with testnet ETH on
# base-sepolia. PRIZE_POOL_MOCK_BALANCE wins over the RPC read so previews
# aren't blocked on RPC outages.
# PRIZE_POOL_ADDRESS=0x...
# PRIZE_POOL_CHAIN=base-sepolia
# PRIZE_POOL_ASSET=ETH
# PRIZE_POOL_RPC_URL=https://sepolia.base.org
# PRIZE_POOL_MOCK_BALANCE=125.00
# VOTER_COOKIE_SECRET=                    # HMAC for 30-day vote-cookie fast path
